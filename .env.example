# Copy this file to .env and fill in your key, OR just export it in your shell:
#   export ANTHROPIC_API_KEY=sk-ant-...
#
# Only required for the "AI Digest" tab inside the dashboard (Insights page).
# Everything else (scraping, storing, browsing, charting) works without it.
ANTHROPIC_API_KEY=sk-ant-your-key-here
